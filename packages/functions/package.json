{
  "name": "@g6k4ever/functions",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Registre des fonctions standard (sum, floor, max, count, year, strftime, defined...) et métier (injectables). Phase 3.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  }
}
