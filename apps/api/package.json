{
  "name": "@g6k4ever/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "API Hono + SQLite — CRUD définitions, exécution, datasources, lock, versions, export. Phase 5.",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "type-build-only": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@g6k4ever/engine": "workspace:*",
    "@g6k4ever/functions": "workspace:*",
    "@g6k4ever/schema": "workspace:*",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30"
  },
  "devDependencies": {
    "@hono/node-server": "^2.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.3"
  }
}
