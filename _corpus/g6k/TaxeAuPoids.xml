	<Sources>
		<Source returnPath="0" returnType="assocArray" label="Tmom" id="1" datasource="cout-certificat-immatriculation" request="SELECT annee, tranchedebut as trancheDebut, tranchefin as trancheFin, tranche, totaltrancheareporter as totalTrancheAReporter, prixaukg as prixAuKg FROM Tmom WHERE %2$d = annee AND %1$d &lt;= trancheFin AND %1$d &gt;= trancheDebut">
			<Parameter name="poids" data="19" type="columnValue" origin="data"></Parameter>
			<Parameter name="annee" data="9" type="columnValue" origin="data"></Parameter>
		</Source>
	</Sources>
	<BusinessRules>
		<BusinessRule id="1" name="R1" attributactive="" label="Affiche la question sur la démarche">
			<Conditions value="defined(#10)">
				<Condition operand="poidsSaisi" operator="present"></Condition>
			</Conditions>
			<IfActions>
				<Action step="1" panel="1" fieldset="1" field="2" id="1" name="showObject" target="field"></Action>
			</IfActions>
			<ElseActions>
				<Action step="1" panel="1" fieldset="1" field="2" id="1" name="hideObject" target="field"></Action>
			</ElseActions>
		</BusinessRule>
		<BusinessRule id="2" name="R2" attributactive="" label="User ne fait pas une 1re immatriculation">
			<Conditions value="defined(#22) &amp;&amp; #22 = 'Autre'">
				<Connector type="all">
					<Condition operand="demarche" operator="present"></Condition>
					<Condition operand="demarche" operator="=" expression="Autre"></Condition>
				</Connector>
			</Conditions>
			<IfActions>
				<Action step="1" panel="1" blockinfo="2" chapter="1" section="2" id="1" name="showObject" target="section"></Action>
			</IfActions>
			<ElseActions>
				<Action step="1" panel="1" blockinfo="2" chapter="1" section="2" id="1" name="hideObject" target="section"></Action>
			</ElseActions>
		</BusinessRule>
